# Postgres connection (Neon, Supabase, Railway, local — anything Postgres).
# Format: postgres://USER:PASS@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL=

# NextAuth — used to sign session JWTs. Generate one fresh: `openssl rand -base64 32`
NEXTAUTH_SECRET=
# Local dev: http://localhost:3000  |  Vercel: leave unset, Vercel auto-fills VERCEL_URL
NEXTAUTH_URL=http://localhost:3000

# Single shared admin login. Share the password with your team out-of-band.
# (For multi-user later, swap to a real users table.)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Where to source page images. In dev, leave empty to fall back to public/pages/p{NNN}.png.
# In prod (Vercel), set to a Vercel Blob URL like https://....public.blob.vercel-storage.com/pages
# Pages are referenced as `${PAGE_IMAGES_BASE_URL}/p{NNN}.png`
PAGE_IMAGES_BASE_URL=

# Python reconstruction service that wraps acd_ingest.labeler_api.reconstruct.
# Lives in the sibling bisaya-reconstruction repo; start it locally with
#   uvicorn service.app.main:app --port 8000
# The labeler only calls it on the POST /api/recon/:entry_id ("Attempt with AI")
# path. GET reads cache from Postgres directly, so this can be down without
# breaking the read flow.
RECONSTRUCTION_SERVICE_URL=http://localhost:8000

